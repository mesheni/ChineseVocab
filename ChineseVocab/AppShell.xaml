<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ChineseVocab.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ChineseVocab"
    Title="ChineseVocab">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Study"
        ContentTemplate="{DataTemplate local:StudyPage}"
        Route="StudyPage" />

    <ShellContent
        Title="Dictation"
        ContentTemplate="{DataTemplate local:DictationPage}"
        Route="DictationPage" />

    <ShellContent
        Title="Character Library"
        ContentTemplate="{DataTemplate local:CharacterLibraryPage}"
        Route="CharacterLibraryPage" />

    <ShellContent
        Title="Sentences"
        ContentTemplate="{DataTemplate local:SentencesPage}"
        Route="SentencesPage" />

    <ShellContent
        Title="Statistics"
        ContentTemplate="{DataTemplate local:StatisticsPage}"
        Route="StatisticsPage" />

</Shell>
