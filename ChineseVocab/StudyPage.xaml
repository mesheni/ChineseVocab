<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ChineseVocab.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ChineseVocab.StudyPage"
             x:DataType="viewModels:StudyViewModel"
             Title="Изучение карточек">

    <ContentPage.BindingContext>
        <viewModels:StudyViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto,Auto"
          Padding="20"
          RowSpacing="20">

        <!-- Заголовок и прогресс -->
        <Frame Grid.Row="0"
               Padding="15"
               CornerRadius="10"
               BackgroundColor="{StaticResource Secondary}"
               HasShadow="True">
            <VerticalStackLayout Spacing="10">
                <Label Text="📚 Изучение карточек"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <ProgressBar Progress="{Binding Progress}"
                             ProgressColor="{StaticResource Primary}"/>

                <Label Text="{Binding ProgressText}"
                       FontSize="14"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Основная область карточки -->
        <Frame Grid.Row="1"
               Padding="30"
               CornerRadius="15"
               BackgroundColor="{StaticResource Surface}"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center">

            <VerticalStackLayout Spacing="25"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <!-- Иероглиф -->
                <Label Text="{Binding CurrentCard.Character}"
                       FontSize="64"
                       FontFamily="Microsoft YaHei"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       VerticalOptions="Center"/>

                <!-- Если показан ответ, отображаем пиньинь и перевод -->
                <VerticalStackLayout Spacing="15"
                                     IsVisible="{Binding IsAnswerVisible}">

                    <!-- Пиньинь -->
                    <Label Text="{Binding CurrentCard.Pinyin}"
                           FontSize="24"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}"/>

                    <!-- Перевод -->
                    <Label Text="{Binding CurrentCard.Definition}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           MaxLines="5"/>

                    <!-- Примеры предложений -->
                    <VerticalStackLayout Spacing="5"
                                         IsVisible="{Binding HasExamples}">
                        <Label Text="Примеры:"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Secondary}"/>
                        <Label Text="{Binding ExamplesText}"
                               FontSize="14"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               MaxLines="3"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Кнопка показа ответа -->
                <Button Text="Показать ответ"
                        Command="{Binding ShowAnswerCommand}"
                        IsVisible="{Binding IsAnswerVisible, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="50"
                        Margin="0,20,0,0"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Кнопки оценки (отображаются только когда показан ответ) -->
        <VerticalStackLayout Grid.Row="2"
                             Spacing="10"
                             IsVisible="{Binding IsAnswerVisible}">

            <Label Text="Насколько хорошо вы знаете эту карточку?"
                   FontSize="16"
                   HorizontalOptions="Center"/>

            <Grid ColumnDefinitions="*,*,*,*,*"
                  ColumnSpacing="10">

                <!-- Оценка 1: Не знаю -->
                <Frame Grid.Column="0"
                       Padding="10"
                       CornerRadius="8"
                       BackgroundColor="#FF6B6B"
                       HasShadow="True">
                    <Button Text="1"
                            Command="{Binding RateCardCommand}"
                            CommandParameter="1"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="50"/>
                </Frame>

                <!-- Оценка 2: Почти -->
                <Frame Grid.Column="1"
                       Padding="10"
                       CornerRadius="8"
                       BackgroundColor="#FFA500"
                       HasShadow="True">
                    <Button Text="2"
                            Command="{Binding RateCardCommand}"
                            CommandParameter="2"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="50"/>
                </Frame>

                <!-- Оценка 3: Средне -->
                <Frame Grid.Column="2"
                       Padding="10"
                       CornerRadius="8"
                       BackgroundColor="#FFD700"
                       HasShadow="True">
                    <Button Text="3"
                            Command="{Binding RateCardCommand}"
                            CommandParameter="3"
                            BackgroundColor="Transparent"
                            TextColor="Black"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="50"/>
                </Frame>

                <!-- Оценка 4: Хорошо -->
                <Frame Grid.Column="3"
                       Padding="10"
                       CornerRadius="8"
                       BackgroundColor="#90EE90"
                       HasShadow="True">
                    <Button Text="4"
                            Command="{Binding RateCardCommand}"
                            CommandParameter="4"
                            BackgroundColor="Transparent"
                            TextColor="Black"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="50"/>
                </Frame>

                <!-- Оценка 5: Отлично -->
                <Frame Grid.Column="4"
                       Padding="10"
                       CornerRadius="8"
                       BackgroundColor="#32CD32"
                       HasShadow="True">
                    <Button Text="5"
                            Command="{Binding RateCardCommand}"
                            CommandParameter="5"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="18"
                            FontAttributes="Bold"
                            HeightRequest="50"/>
                </Frame>
            </Grid>

            <Label Text="1: Не знаю, 2: Почти, 3: Средне, 4: Хорошо, 5: Отлично"
                   FontSize="12"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Secondary}"/>
        </VerticalStackLayout>

        <!-- Нижняя панель с дополнительными кнопками -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,*"
              ColumnSpacing="15">

            <Button Grid.Column="0"
                    Text="Настройки"
                    Command="{Binding OpenSettingsCommand}"
                    BackgroundColor="{StaticResource Secondary}"
                    TextColor="{StaticResource OnSecondary}"
                    CornerRadius="10"
                    HeightRequest="50"/>

            <Button Grid.Column="1"
                    Text="Вернуться на главную"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"/>
        </Grid>

        <!-- Индикатор загрузки -->
        <ActivityIndicator Grid.RowSpan="4"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
    </Grid>
</ContentPage>
