<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChineseVocab.CharacterLibraryPage"
             Title="База иероглифов">

    <ContentPage.BindingContext>
        <!-- ViewModel will be set later -->
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Label Text="База иероглифов (БКРС)"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}"/>

            <Label Text="Здесь будет отображаться база китайских иероглифов с поиском и фильтрацией."
                   FontSize="16"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            <Label Text="Страница в разработке..."
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource Secondary}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
