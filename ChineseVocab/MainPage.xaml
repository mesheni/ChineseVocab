<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ChineseVocab.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ChineseVocab.MainPage"
             x:DataType="viewModels:MainViewModel"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <viewModels:MainViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Spacing="30" Padding="20">

            <!-- Заголовок и приветствие -->
            <VerticalStackLayout Spacing="15">
                <Label Text="ChineseVocab"
                       FontSize="32"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource Primary}"/>

                <Label Text="{Binding WelcomeMessage}"
                       FontSize="18"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Карточки с кнопками навигации -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="*,*,*"
                  ColumnSpacing="15" RowSpacing="15">

                <!-- Карточка изучения -->
                <Frame Grid.Column="0" Grid.Row="0"
                       Padding="15" CornerRadius="15"
                       BackgroundColor="{StaticResource Secondary}"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="FillAndExpand"
                                         VerticalOptions="FillAndExpand">
                        <Label Text="📚"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Изучение карточек"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Начать"
                                Command="{Binding GoToStudyCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Карточка диктанта -->
                <Frame Grid.Column="1" Grid.Row="0"
                       Padding="15" CornerRadius="15"
                       BackgroundColor="{StaticResource Secondary}"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="FillAndExpand"
                                         VerticalOptions="FillAndExpand">
                        <Label Text="✍️"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Диктант"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Начать"
                                Command="{Binding GoToDictationCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Карточка базы иероглифов -->
                <Frame Grid.Column="0" Grid.Row="1"
                       Padding="15" CornerRadius="15"
                       BackgroundColor="{StaticResource Secondary}"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="FillAndExpand"
                                         VerticalOptions="FillAndExpand">
                        <Label Text="🔠"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label Text="База иероглифов"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Открыть"
                                Command="{Binding GoToCharacterLibraryCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Карточка примеров предложений -->
                <Frame Grid.Column="1" Grid.Row="1"
                       Padding="15" CornerRadius="15"
                       BackgroundColor="{StaticResource Secondary}"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="FillAndExpand"
                                         VerticalOptions="FillAndExpand">
                        <Label Text="💬"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Примеры предложений"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Открыть"
                                Command="{Binding GoToSentencesCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- Карточка статистики -->
                <Frame Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"
                       Padding="15" CornerRadius="15"
                       BackgroundColor="{StaticResource Secondary}"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="10"
                                         HorizontalOptions="FillAndExpand"
                                         VerticalOptions="FillAndExpand">
                        <Label Text="📊"
                               FontSize="28"
                               HorizontalOptions="Center"/>
                        <Label Text="Статистика и прогресс"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Просмотреть"
                                Command="{Binding GoToStatisticsCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                CornerRadius="10"
                                Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Индикатор загрузки -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
